# Copy to .env.local (never commit secrets)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI
OPENAI_API_KEY=

# Supabase service role (server only — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# App URL (Vercel / local)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (subscriptions — Small Business $50, Enterprise $400)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional publishable key if you add Stripe.js later
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
